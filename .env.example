# Database (Neon PostgreSQL or any PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname

# VAPID keys — generate with: npm run vapid:generate
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@yourdomain.com

# Admin key — fallback secret for CLI/script access to admin routes
ADMIN_KEY=change-me-to-a-long-random-string

# JWT secret — signs dashboard login tokens (defaults to ADMIN_KEY if not set)
# Recommended: set this to a separate random string in production
JWT_SECRET=change-me-to-a-different-long-random-string

# Port (optional, defaults to 3000)
PORT=3000
